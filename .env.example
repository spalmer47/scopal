# .env.example — documents every env var the project reads.
# Commit THIS file to git WITHOUT VALUES.
# Never commit .env, .env.local, or .env.*.local (they are gitignored).
# Real values are set in the Vercel dashboard (Project > Settings > Environment Variables)
# and locally in .env.local for development.

# ─── Phase 4 (contact form) ──────────────────────────────────────────────
# Resend API key for outbound email notifications (server-side secret).
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=

# Email address that receives contact-form submissions.
CONTACT_TO_EMAIL=
