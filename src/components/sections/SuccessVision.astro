---
// No props.
const items = [
  'You sign contracts with confidence, because your GC reviewed them.',
  'You move fast on deals and hires, because legal isn\'t a bottleneck.',
  'You sleep better, because someone who knows your business is watching for what could go wrong before it does.',
];
---
<section class="bg-surface py-12 md:py-16">
  <div class="mx-auto max-w-[1200px] px-md md:px-lg lg:px-xl">
    <div class="max-w-2xl">
      <h2 class="font-display font-semibold text-2xl md:text-[28px] text-ink leading-[1.25]">
        What it feels like to have a legal partner, not a vendor.
      </h2>
      <ul class="mt-6 space-y-4 list-none">
        {items.map((item) => (
          <li class="flex items-start gap-3 text-base leading-relaxed text-ink">
            <span class="text-brand-blue-500 font-semibold mt-0.5 flex-shrink-0" aria-hidden="true">&rarr;</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
