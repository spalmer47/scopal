---
interface Props {
  faqs: Array<{ q: string; a: string }>;
}
const { faqs } = Astro.props;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
