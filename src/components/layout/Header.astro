---
import { FIRM } from '../../lib/constants';
---
<header class="sticky top-0 z-50 bg-surface border-b border-border shadow-sm">
  <div class="mx-auto max-w-[1200px] px-md md:px-lg lg:px-xl h-[64px] md:h-[80px] flex items-center justify-between">

    <!-- Logo -->
    <a
      href="/"
      aria-label={`${FIRM.shortName} — Home`}
      class="focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-blue-500"
    >
      <img
        src="/logo.svg"
        alt={FIRM.shortName}
        width="186"
        height="36"
        class="h-9 w-auto"
      />
    </a>

    <!-- Desktop nav + CTA (hidden on mobile) -->
    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-8">

      <!-- Practice Areas dropdown -->
      <div class="relative">
        <button
          id="practice-btn"
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="practice-dropdown"
          class="text-base text-ink hover:text-brand-blue-500 flex items-center gap-1 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500"
        >
          Practice Areas
          <svg width="12" height="8" viewBox="0 0 12 8" aria-hidden="true" focusable="false">
            <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </button>
        <ul
          id="practice-dropdown"
          hidden
          class="absolute top-full left-0 mt-1 w-56 bg-surface border border-border rounded-lg shadow-md py-2 z-50"
        >
          <li>
            <a href="/practice-areas/corporate-law" class="block px-4 py-2 text-base text-ink hover:text-brand-blue-500 hover:bg-surface-muted transition-colors">
              Corporate Law
            </a>
          </li>
          <li>
            <a href="/practice-areas/fractional-general-counsel" class="block px-4 py-2 text-base text-ink hover:text-brand-blue-500 hover:bg-surface-muted transition-colors">
              Fractional GC
            </a>
          </li>
        </ul>
      </div>

      <a href="/coaching" class="text-base text-ink hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500 transition-colors">Coaching</a>
      <a href="/attorneys/scott-palmer" class="text-base text-ink hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500 transition-colors">Scott Palmer</a>
      <a href="/blog" class="text-base text-ink hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500 transition-colors">Blog</a>
      <a
        href="/contact"
        class="bg-brand-blue-500 hover:bg-brand-blue-600 text-white text-base font-semibold py-3 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:ring-offset-2"
      >
        Book a Fit Call
      </a>
    </nav>

    <!-- Mobile hamburger button (hidden on desktop) -->
    <button
      id="hamburger"
      type="button"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Open navigation menu"
      class="md:hidden p-3 text-ink hover:text-ink-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500"
    >
      <svg width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true" focusable="false">
        <rect y="0"  width="20" height="2" rx="1" fill="currentColor"/>
        <rect y="6"  width="20" height="2" rx="1" fill="currentColor"/>
        <rect y="12" width="20" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav"
    class="hidden md:hidden bg-surface border-b border-border"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-[1200px] px-md py-6 flex flex-col gap-6">
      <!-- Practice Areas disclosure group -->
      <details class="group">
        <summary class="text-base text-ink hover:text-brand-blue-500 py-[12px] cursor-pointer list-none flex items-center justify-between focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">
          Practice Areas
          <svg width="12" height="8" viewBox="0 0 12 8" aria-hidden="true" class="transition-transform group-open:rotate-180">
            <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </summary>
        <div class="pl-4 flex flex-col gap-3 mt-2">
          <a href="/practice-areas/corporate-law" class="text-base text-ink hover:text-brand-blue-500 py-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">Corporate Law</a>
          <a href="/practice-areas/fractional-general-counsel" class="text-base text-ink hover:text-brand-blue-500 py-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">Fractional GC</a>
        </div>
      </details>
      <a href="/coaching" class="text-base text-ink hover:text-brand-blue-500 py-[12px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">Coaching</a>
      <a href="/attorneys/scott-palmer" class="text-base text-ink hover:text-brand-blue-500 py-[12px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">Scott Palmer</a>
      <a href="/blog" class="text-base text-ink hover:text-brand-blue-500 py-[12px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">Blog</a>
      <a
        href="/contact"
        class="block w-full text-center bg-brand-blue-500 hover:bg-brand-blue-600 text-white text-base font-semibold py-3 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:ring-offset-2"
      >
        Book a Fit Call
      </a>
    </div>
  </div>
</header>

<script src="/js/nav.js" defer></script>
