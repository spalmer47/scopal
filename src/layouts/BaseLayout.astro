---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/seo/SEO.astro';
import LegalServiceSchema from '../components/seo/LegalServiceSchema.astro';
import WebSiteSchema from '../components/seo/WebSiteSchema.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  emitOrgSchema?: boolean;
  emitWebSiteSchema?: boolean;
}
const { title, description, ogImage, ogType = 'website', noindex = false, emitOrgSchema = false, emitWebSiteSchema = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Inter-Regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/Fraunces-SemiBold.woff2" crossorigin />
    <SEO {title} {description} {ogImage} {ogType} {noindex} />
    {emitOrgSchema && <LegalServiceSchema />}
    {emitWebSiteSchema && <WebSiteSchema />}
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-ink font-body">
    <script>
      // Scroll-reveal animations.
      // Only runs if the user hasn't requested reduced motion.
      // Sets opacity/transform via inline styles (not CSS classes) to avoid
      // race conditions with deferred module script execution.
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const sections = Array.from(document.querySelectorAll('[data-animate]'));
        if (!sections.length) return;

        // Only hide sections that start below the visible area —
        // never hide content that's already on screen when the page loads.
        sections.forEach(function (el) {
          if (el.getBoundingClientRect().top >= window.innerHeight) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(24px)';
            el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            // Staggered children (Plan step cards)
            el.querySelectorAll('[data-delay]').forEach(function (child) {
              child.style.transitionDelay = (parseInt(child.dataset.delay) * 0.1) + 's';
            });
          }
        });

        const observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                var el = entry.target;
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
                observer.unobserve(el);
              }
            });
          },
          { threshold: 0.1 }
        );

        sections.forEach(function (el) {
          if (el.style.opacity === '0') observer.observe(el);
        });
      })();
    </script>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-surface focus:text-ink focus:px-md focus:py-sm focus:outline-2 focus:outline-offset-2 focus:outline-brand-blue-500"
    >Skip to content</a>
    <Header />
    <main id="main" class="flex-1"><slot /></main>
    <Footer />
  </body>
</html>
