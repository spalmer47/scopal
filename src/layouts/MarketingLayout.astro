---
import BaseLayout from './BaseLayout.astro';
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  emitOrgSchema?: boolean;
  emitWebSiteSchema?: boolean;
}
const props = Astro.props;
---
<BaseLayout {...props}><slot /></BaseLayout>
