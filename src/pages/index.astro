---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import ProactiveInsight from '../components/sections/ProactiveInsight.astro';
import Plan from '../components/sections/Plan.astro';
import Stakes from '../components/sections/Stakes.astro';
import SuccessVision from '../components/sections/SuccessVision.astro';
import CTASection from '../components/sections/CTASection.astro';
---
<MarketingLayout
  title="General Counsel for SaaS Companies | Scopal Firm"
  description="Scopal Firm gives SaaS founders a dedicated General Counsel on subscription — available consistently, invested in your long-term success, priced for companies not ready to hire full-time."
  emitOrgSchema={true}
  emitWebSiteSchema={true}
>
  <!-- StoryBrand sequence: Hero → Trust → Guide (ProactiveInsight) → Plan → Stakes → Success → CTA -->
  <Hero />
  <TrustStrip />
  <ProactiveInsight />
  <Plan />
  <Stakes />
  <SuccessVision />
  <CTASection />
</MarketingLayout>
