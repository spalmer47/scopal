---
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(sorted, { pageSize: 10 });
}

const { page } = Astro.props;
---
<MarketingLayout
  title="Blog — Annandale, NJ | Scopal Firm"
  description="Legal insights for SaaS founders from Scott A. Palmer, fractional general counsel at Scopal Firm, LLC."
>
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-[1200px] px-md md:px-lg lg:px-xl">
      <h1 class="font-display font-semibold text-4xl md:text-5xl text-ink leading-[1.15] mb-4">
        Insights
      </h1>
      <p class="text-base md:text-lg text-ink-muted leading-relaxed mb-12">
        Legal perspective for SaaS founders, by Scott A. Palmer.
      </p>

      {page.data.length === 0 && (
        <p class="text-ink-muted">No posts yet. Check back soon.</p>
      )}

      <ul class="space-y-10">
        {page.data.map((post) => (
          <li>
            <article>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-sm text-ink-muted"
              >
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="mt-2 font-display font-semibold text-2xl text-ink leading-[1.25]">
                <a
                  href={`/blog/${post.id}`}
                  class="hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500 transition-colors"
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-3 text-base leading-relaxed text-ink-muted">{post.data.description}</p>
              <a
                href={`/blog/${post.id}`}
                class="mt-4 inline-block text-brand-blue-500 hover:text-brand-blue-600 font-semibold text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500 transition-colors"
              >
                Read more →
              </a>
            </article>
          </li>
        ))}
      </ul>

      {(page.url.prev || page.url.next) && (
        <nav aria-label="Blog pagination" class="mt-16 flex gap-6 justify-between text-sm">
          {page.url.prev && (
            <a href={page.url.prev} class="underline underline-offset-2 hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">
              ← Newer posts
            </a>
          )}
          {page.url.next && (
            <a href={page.url.next} class="underline underline-offset-2 hover:text-brand-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue-500">
              Older posts →
            </a>
          )}
        </nav>
      )}
    </div>
  </section>
</MarketingLayout>
