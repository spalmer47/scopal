---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CTASection from '../components/sections/CTASection.astro';
import { getCollection, render } from 'astro:content';

const entries = await getCollection('coaching');
const entry = entries[0];
const { Content } = await render(entry);
---
<MarketingLayout
  title="Legal Executive Coaching | Scopal Firm"
  description={entry.data.description}
>
  <!-- Terra-cotta hero — visually distinct from the law pages -->
  <section class="bg-coaching-terra hero-pattern py-16 lg:py-24">
    <div class="mx-auto max-w-[1200px] px-md md:px-lg lg:px-xl">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-sm font-semibold text-white/60 uppercase tracking-wide mb-4">For In-House Attorneys &amp; General Counsel</p>
        <h1 class="font-display font-semibold text-4xl lg:text-5xl text-white leading-[1.15]">
          {entry.data.title}
        </h1>
        <p class="mt-6 text-base leading-relaxed text-white/75 max-w-prose mx-auto">
          {entry.data.description}
        </p>
        <div class="mt-8">
          <a
            href="/contact"
            class="inline-block bg-white hover:bg-white/90 text-coaching-terra text-base font-semibold py-3 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-coaching-terra"
          >
            Book a Discovery Call
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="mx-auto max-w-[1200px] px-md md:px-lg lg:px-xl py-12 md:py-16">
    <div class="max-w-prose mx-auto">
      <div class="prose prose-lg [--tw-prose-links:theme(colors.coaching-terra)]">
        <Content />
      </div>
    </div>
  </article>

  <CTASection />
</MarketingLayout>
